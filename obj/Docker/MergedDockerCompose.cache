name: dockercompose17857876492910320990
services:
  roomservice:
    build:
      context: C:\Users\petry\source\repos\RoomService
      dockerfile: RoomService\Dockerfile
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
    image: roomservice
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
