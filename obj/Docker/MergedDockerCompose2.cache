name: dockercompose17857876492910320990
services:
  postgres:
    container_name: roomservice_postgres
    environment:
      POSTGRES_DB: roomservice
      POSTGRES_PASSWORD: postgres
      POSTGRES_USER: postgres
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U postgres
      timeout: 5s
      interval: 10s
      retries: 5
    image: postgres:15
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5432
        published: "5432"
        protocol: tcp
    volumes:
      - type: volume
        source: postgres_data
        target: /var/lib/postgresql/data
        volume: {}
  roomservice:
    build:
      context: C:\Users\petry\source\repos\RoomService
      dockerfile: RoomService\Dockerfile
    depends_on:
      postgres:
        condition: service_started
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
      ASPNETCORE_Kestrel__Certificates__Default__Password: yourpassword
      ASPNETCORE_Kestrel__Certificates__Default__Path: /https/aspnetapp.pfx
      ASPNETCORE_URLS: https://+:443;http://+:80
      ConnectionStrings__DefaultConnection: Host=postgres;Database=roomservice;Username=postgres;Password=postgres
    image: roomservice
    networks:
      default: null
    ports:
      - mode: ingress
        target: 80
        published: "8080"
        protocol: tcp
      - mode: ingress
        target: 443
        published: "8081"
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Users\petry\.aspnet\https
        target: /https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\petry\AppData\Roaming/Microsoft/UserSecrets
        target: C:\Users\ContainerUser\AppData\Roaming\Microsoft\UserSecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\petry\AppData\Roaming/Microsoft/UserSecrets
        target: C:\Users\ContainerAdministrator\AppData\Roaming\Microsoft\UserSecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\petry\AppData\Roaming/ASP.NET/Https
        target: C:\Users\ContainerUser\AppData\Roaming\ASP.NET\Https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\petry\AppData\Roaming/ASP.NET/Https
        target: C:\Users\ContainerAdministrator\AppData\Roaming\ASP.NET\Https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\petry\AppData\Roaming/Microsoft/UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\petry\AppData\Roaming/ASP.NET/Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
networks:
  default:
    name: dockercompose17857876492910320990_default
volumes:
  postgres_data:
    name: dockercompose17857876492910320990_postgres_data