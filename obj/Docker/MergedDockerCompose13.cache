name: dockercompose17857876492910320990
services:
  postgres:
    container_name: roomservice_postgres
    environment:
      POSTGRES_DB: roomservice
      POSTGRES_PASSWORD: postgres
      POSTGRES_USER: postgres
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U postgres -d roomservice
      timeout: 5s
      interval: 10s
      retries: 5
    image: postgres:15-alpine
    networks:
      roomservice_network: null
    ports:
      - mode: ingress
        target: 5432
        published: "5433"
        protocol: tcp
    volumes:
      - type: volume
        source: postgres_data
        target: /var/lib/postgresql/data
        volume: {}
  roomservice:
    build:
      context: C:\Users\petry\source\repos\RoomService
      dockerfile: RoomService/Dockerfile
    container_name: roomservice_api
    depends_on:
      postgres:
        condition: service_healthy
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
      ASPNETCORE_URLS: http://+:8080
      ConnectionStrings__DefaultConnection: Host=postgres;Database=roomservice;Username=postgres;Password=postgres
    image: roomservice
    networks:
      roomservice_network: null
    ports:
      - mode: ingress
        target: 8080
        published: "8080"
        protocol: tcp
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Users\petry\AppData\Roaming/Microsoft/UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\petry\AppData\Roaming/Microsoft/UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\petry\AppData\Roaming/ASP.NET/Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\petry\AppData\Roaming/ASP.NET/Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
networks:
  roomservice_network:
    name: dockercompose17857876492910320990_roomservice_network
    driver: bridge
volumes:
  postgres_data:
    name: dockercompose17857876492910320990_postgres_data
    driver: local